# Friseur-Demo — Umgebungsvariablen
# Alle optional: ohne sie läuft die Demo mit Mock-Verhalten
# (Buchung ohne Persistenz, E-Mail als Mock, KI-Chat mit Fallback-Antwort).

# ── Öffentliche URL ─────────────────────────────────────────────────────────
# Für Metadaten, OG-Bilder, Stornierungslinks
NEXT_PUBLIC_APP_URL=https://friseur-demo.vercel.app

# ── Infrastruktur: Upstash Redis ─────────────────────────────────────────────
# Speichert belegte Terminslots, Wartelisten, Rate-Limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── E-Mail: Resend ───────────────────────────────────────────────────────────
# Buchungsbestätigungen, Erinnerungen, Review-Requests
RESEND_API_KEY=
# Empfänger der Buchungsmail (Standard: salonConfig.email)
SALON_EMAIL=
# Absenderadresse (verifizierte Domain; Standard: onboarding@resend.dev)
BOOKING_EMAIL_FROM=

# ── KI-Chat: Google Gemini ───────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Admin-Bereich /admin ─────────────────────────────────────────────────────
# Passwort für den Admin-Login (Standard: haarmonie-demo)
ADMIN_PASSWORD=

# Session-Signing-Secret — verhindert, dass das Klartext-Passwort im Cookie steht.
# Generieren: openssl rand -hex 32
SESSION_SECRET=

# ── Automatisierung ──────────────────────────────────────────────────────────
# Vercel Cron Secret — schützt den /api/cron/reminders Endpunkt vor fremden Aufrufen.
# Muss in Vercel Dashboard unter "Cron Secret" eingetragen sein.
# Generieren: openssl rand -hex 32
CRON_SECRET=

# Google Review-Link (für Review-Request-E-Mail nach Terminabschluss)
# Aus Google Maps "Bewertung schreiben"-Button kopieren
GOOGLE_REVIEW_URL=
