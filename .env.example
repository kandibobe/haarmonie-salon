# Friseur-Demo — Umgebungsvariablen
# Alle optional: ohne sie läuft die Demo mit Mock-Verhalten
# (Buchung ohne Persistenz, E-Mail als Mock, KI-Chat mit Fallback-Antwort).

# Öffentliche URL (für Metadaten / Sitemap)
NEXT_PUBLIC_APP_URL=https://friseur-demo.vercel.app

# Upstash Redis — speichert belegte Terminslots (echte Slot-Blockierung)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — Versand der Buchungsbestätigung per E-Mail
RESEND_API_KEY=
# Empfänger der Buchungsmail (Standard: salonConfig.email)
SALON_EMAIL=
# Absenderadresse (verifizierte Domain bei Resend; Standard: onboarding@resend.dev)
BOOKING_EMAIL_FROM=

# Google Gemini — KI-Empfang Chat
GOOGLE_GENERATIVE_AI_API_KEY=
